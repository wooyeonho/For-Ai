# For-Ai — environment variables
# Copy to .env.local for local dev, and set these in your Vercel project
# (Settings → Environment Variables) before deploying to production.
#
# Legend:  [REQUIRED]  app feature breaks without it
#          [OPTIONAL]  has a safe fallback / graceful degradation

# ─────────────────────────────────────────────────────────────────────────────
# Public submissions (community posts, topic suggestions, reports, AI-answer reports)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for any public submission]
# Secret salt used to derive an anonymous contributor_hash from the request
# (raw IP is never stored). If this is missing, ALL public submission endpoints
# (/api/posts, /api/suggest-topic, /api/report/*, /api/hallucination/*) return
# HTTP 500 and the submit buttons appear to "do nothing".
# Generate one: `openssl rand -hex 32`
CONTRIBUTOR_SALT=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — community, dynamic documents, telemetry, admin
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for community + dynamic/DB-backed documents + popularity stats]
# Without these, the site still renders from static seed data, but the community
# feed, "Most Cited by AI" stats, and Supabase-promoted documents stay empty.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED for the /admin/* dashboards]
# Service-role key for privileged admin API routes. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Database migrations (deploy-time only — not read by the running app)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED to run `npm run db:migrate`] Direct Postgres connection string for
# this project, used only to apply supabase/migrations/*.sql. Find it in the
# Supabase dashboard under Project Settings → Database → Connection string
# (URI, "Direct connection"), then fill in the password:
#   postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
# Set this once, then run `npm run db:migrate` any time there are new files in
# supabase/migrations/ to apply. (Not wired into CI to auto-run on every merge —
# ask explicitly if you want that, since it would apply schema changes to
# production with no human review step.)
SUPABASE_DB_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Admin authentication
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED to use /admin/*] Secret entered in the admin UI and sent as
# `x-admin-secret`. Admin API routes reject requests without a matching value.
ADMIN_SECRET=
# [REQUIRED to use /admin/*] CSRF guard secret paired with the `x-admin-csrf` header.
ADMIN_CSRF_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Watcher email digests (supabase/functions/notify-watchers)
# ─────────────────────────────────────────────────────────────────────────────
# [REQUIRED for watcher email notifications] Shared secret the notify-watchers
# Supabase Edge Function checks before running (it fails closed — 503 if unset,
# 401 if the caller's secret doesn't match). Set the SAME value in TWO places:
#   1. This repo's GitHub Actions secret NOTIFY_WATCHERS_SECRET
#      (used by .github/workflows/claims-ops.yml to call the function)
#   2. The notify-watchers Edge Function's own secret in Supabase
#      (Dashboard → Edge Functions → notify-watchers → Secrets, or
#      `supabase secrets set NOTIFY_WATCHERS_SECRET=... --project-ref <ref>`)
# This var is not read by the Next.js app itself, so it does not belong in
# Vercel's env vars — only in the two places above.
# Generate one: `openssl rand -hex 32`
NOTIFY_WATCHERS_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Site URL & locale
# ─────────────────────────────────────────────────────────────────────────────
# [OPTIONAL but recommended] Canonical origin used for SEO, OpenGraph, sitemap,
# JSON-LD, and API-docs example URLs. Falls back to the default Vercel domain.
# Set this to your real production domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://for-ai-e4mm.vercel.app

# [OPTIONAL but recommended in production] Base URL the app uses to call its
# OWN API routes during server-side rendering (app/contribute, leaderboard,
# country-quest pages self-fetch /api/gamification/* at request time). Falls
# back to http://localhost:3000, so without this set in Vercel those pages
# can render empty in production. Same value as NEXT_PUBLIC_SITE_URL, no
# trailing slash.
NEXT_PUBLIC_APP_URL=https://for-ai-e4mm.vercel.app

# [OPTIONAL] Final fallback locale when Accept-Language has no match.
# One of: ko en hi ar es ja zh. Defaults to "en".
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─────────────────────────────────────────────────────────────────────────────
# AI consensus engine (admin-only candidate generation)
# ─────────────────────────────────────────────────────────────────────────────
# [OPTIONAL, but at least one is needed to generate topic candidates] Used only
# by POST /api/admin/generate-candidates (admin-gated, never reachable by
# public users). None of these being set does not break the site — it just
# means the AI candidate-generation admin action has nothing to call.
# More providers set = stronger multi-model consensus (see lib/consensus.ts).
PERPLEXITY_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
# Shared by all 4 NVIDIA model variants (nvidia, nvidia_llama_70b,
# nvidia_nemotron_70b, nvidia_llama_8b) — one key covers all of them.
NVIDIA_API_KEY=
# [OPTIONAL] Overrides the default NVIDIA model
# (nvidia/llama-3.1-nemotron-70b-instruct) used by the plain "nvidia" provider.
NVIDIA_MODEL=
