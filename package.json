{
  "name": "for-ai",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "rm -rf .tmp/tests && tsc --module commonjs --target ES2020 --moduleResolution node --jsx react-jsx --esModuleInterop --skipLibCheck --resolveJsonModule --noEmit false --outDir .tmp/tests lib/citation-status.ts lib/i18n/locales.ts lib/i18n/routing.ts lib/i18n/claim-alignment.ts lib/ai-providers.ts lib/consensus.ts lib/admin-api.ts lib/contributor-streaks.ts lib/point-awards.ts lib/gamification-leaderboard.ts lib/submission-limits.ts app/api/admin/login/route.ts test/citation-status.test.ts test/submission-limits.test.ts test/i18n-routing.test.ts test/claim-alignment.test.ts test/consensus.test.ts test/admin-auth.test.ts test/contributor-streaks.test.ts test/gamification.test.ts test/gamification-leaderboard.test.ts && node scripts/stub-server-only-for-tests.mjs && node --test .tmp/tests/test/*.test.js",
    "generate:question-candidates": "node scripts/generate-question-candidates.mjs",
    "generate:seed-candidates": "node scripts/seed-to-candidates.mjs",
    "ci:guards": "node scripts/ci-guards.mjs all",
    "claims:status": "node scripts/verified-claims.mjs status",
    "claims:scaffold": "node scripts/verified-claims.mjs scaffold",
    "claims:validate": "node scripts/verified-claims.mjs validate",
    "ai:doctor": "node scripts/ai-readiness-doctor.mjs",
    "ai:lazycodex:install": "npx lazycodex-ai install",
    "ai:lazycodex:doctor": "node scripts/ai-readiness-doctor.mjs",
    "ai:prompt": "node scripts/print-ai-prompt.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "doctor:ai-readiness": "node scripts/doctor-ai-readiness.mjs",
    "claims:apply": "node scripts/verified-claims.mjs apply",
    "claims:batch": "node scripts/verified-claims.mjs batch",
    "claims:generate-payloads": "node scripts/verified-claims.mjs generate-payloads",
    "smoke:production-submissions": "node scripts/production-submission-smoke.mjs",
    "claims:recommend": "node scripts/verified-claims.mjs recommend",
    "check:citation-surfaces": "node scripts/check-citation-surfaces.mjs",
    "job:triage-topic-candidates": "node scripts/jobs/triage-topic-candidates.mjs",
    "job:find-stale-claims": "node scripts/jobs/find-stale-claims.mjs",
    "job:check-source-health": "node scripts/jobs/check-source-health.mjs",
    "job:generate-admin-digest": "node scripts/jobs/generate-admin-digest.mjs",
    "job:check-security-baseline": "node scripts/jobs/check-security-baseline.mjs",
    "admin:digest": "node scripts/jobs/generate-admin-digest.mjs",
    "db:migrate": "npx supabase db push --db-url \"$SUPABASE_DB_URL\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "eslint": "9.28.0",
    "eslint-config-next": "15.5.19",
    "typescript": "5.8.3"
  }
}
